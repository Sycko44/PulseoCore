# PulseoCore environment example
# Copy to .env locally and adapt values.

APP_ENV=development
APP_NAME=PulseoCore
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
WEB_BASE_URL=http://localhost:3000
MOBILE_API_BASE_URL=http://10.0.2.2:8000/v1

SECRET_KEY=change-me
JWT_SECRET=change-me
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

POSTGRES_DB=pulseo
POSTGRES_USER=pulseo
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://pulseo:change-me@postgres:5432/pulseo

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_BUCKET=pulseo-assets
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=change-me

SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@pulseo.local

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_HOSTS=localhost,127.0.0.1

SENTRY_DSN=
LOG_LEVEL=INFO

FEATURE_SOS=true
FEATURE_RITUALS=true
FEATURE_PHOENIX=true
FEATURE_SANDBOX_REVIEW=true
