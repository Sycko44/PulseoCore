APP_ENV=staging
APP_NAME=PulseoCore
APP_HOST=0.0.0.0
APP_PORT=8000
WEB_BASE_URL=https://pulseo.me
MOBILE_API_BASE_URL=https://api.pulseo.me
SECRET_KEY=replace-me
JWT_SECRET=replace-me
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=30
POSTGRES_DB=pulseo
POSTGRES_USER=pulseo
POSTGRES_PASSWORD=replace-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://pulseo:replace-me@postgres:5432/pulseo
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
OBJECT_STORAGE_ENDPOINT=replace-me
OBJECT_STORAGE_BUCKET=replace-me
OBJECT_STORAGE_ACCESS_KEY=replace-me
OBJECT_STORAGE_SECRET_KEY=replace-me
SMTP_HOST=replace-me
SMTP_PORT=587
SMTP_USERNAME=replace-me
SMTP_PASSWORD=replace-me
SMTP_FROM=replace-me
OPC_ARCHIVE_PATH=/opt/pulseo/archive/opc
MANIFEST_ARCHIVE_PATH=/opt/pulseo/archive/manifests
SQLITE_PATH=/opt/pulseo/archive/runtime/pulseo.sqlite3
