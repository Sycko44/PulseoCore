FROM python:3.12-slim

WORKDIR /app

COPY services/api/requirements.minimum.txt /app/requirements.minimum.txt
RUN pip install --no-cache-dir -r /app/requirements.minimum.txt

COPY services/api /app
COPY legacy /app/legacy

RUN python bootstrap_db.py

EXPOSE 8000

CMD ["uvicorn", "pulseo_minimum:app", "--host", "0.0.0.0", "--port", "8000"]
